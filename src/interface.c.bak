  label1989582 = gtk_label_new (_("<span font= \" 11\"\nforeground=\"black\">\n\nV\303\251rifier infos membres r\303\251guli\303\250rement.\n\nSupprimer seulement si toutes les inscriptions sont archiv\303\251es.\n\nUtiliser les filtres de reherche pour g\303\251rer facilement.\n\n\n\n\nAjouter/Modifier un cours avec entra\303\256neur et horaire.\n\n\n\n\nSupprimer seulement les cours annul\303\251s.\n\n\n\n\nAjouter/Modifier avec comp\303\251tences et disponibilit\303\251s.\n\n\303\211viter chevauchements d\342\200\231horaires.\n\nSupprimer uniquement s\342\200\231il n\342\200\231est plus affect\303\251 \303\240 un cours ou \303\251v\303\251nement.\n\n\n\n\nAjouter/Modifier un centre avec son adresse et \303\251quipements.\n\nSupprimer un centre uniquement s\342\200\231il n\342\200\231a aucun cours ou \303\251v\303\251nement actif.\n\n\n\n\nCr\303\251er/Modifier/Supprimer selon le planning.\n\nInformer les membres \303\240 l\342\200\231avance.\n\n\n\nV\303\251rifier participation et popularit\303\251 des cours.\n\nSauvegarder les donn\303\251es r\303\251guli\303\250rement.</span>"));
  gtk_widget_show (label1989582);
  gtk_fixed_put (GTK_FIXED (fixed5632), label1989582, 96, 56);
  gtk_widget_set_size_request (label1989582, 528, 856);
  gtk_label_set_use_markup (GTK_LABEL (label1989582), TRUE);

