  label1989610 = gtk_label_new (_("<span font= \" 11\"\nforeground=\"black\">\n\n\nVous pouvez demander un entra\303\256neur priv\303\251 adapt\303\251 \303\240 vos besoins. Avant de confirmer,\n utilisez les filtres pour v\303\251rifier sa disponibilit\303\251 et \303\251viter tout conflit d\342\200\231horaire.\n\n\n\nChoisissez un cours disponible et inscrivez-vous en quelques clics. V\303\251rifiez le nombre de places\n et l\342\200\231horaire avant de valider votre inscription.\n\n\n\n\nEnregistrez vos pr\303\251f\303\251rences de cours pour recevoir automatiquement un email lorsqu\342\200\231un cours compatible \nest ajout\303\251. Cela vous permet de ne jamais manquer les cours qui vous int\303\251ressent.\n\n\n\n\nConsultez les \303\251v\303\251nements ouverts aux membres et inscrivez-vous facilement. Vous pouvez voir tous les d\303\251tails\n et dates pour mieux planifier votre participation.\n\n\n\nUtilisez les filtres pour trouver un entra\303\256neur ou un cours disponible rapidement.\n\nV\303\251rifiez r\303\251guli\303\250rement vos emails pour recevoir les notifications des cours ou \303\251v\303\251nements compatibles.\n\nPensez \303\240 mettre \303\240 jour vos pr\303\251f\303\251rences si vos disponibilit\303\251s changent.</span>"));
  gtk_widget_show (label1989610);
  gtk_fixed_put (GTK_FIXED (fixed5633), label1989610, 40, 96);
  gtk_widget_set_size_request (label1989610, 744, 848);
  gtk_label_set_use_markup (GTK_LABEL (label1989610), TRUE);

